Screen {
    layout: vertical;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface-lighten-2;
    scrollbar-color: $surface-lighten-2;
    scrollbar-color-hover: $text-muted;
    scrollbar-color-active: $text;
    scrollbar-corner-color: $surface;
}

#body {
    height: 1fr;
}

#conversation_panel {
    width: 2fr;
    height: 100%;
}

#side_panel {
    width: 1fr;
    min-width: 34;
    height: 100%;
    background: $background;
}

#events {
    background: $background;
    color: $text;
}

#events > ContentTabs,
#events ContentTabs > #tabs-scroll,
#events ContentTabs #tabs-list-bar,
#events ContentTabs #tabs-list {
    background: $background;
    color: $text;
}

#events ContentTabs Tab,
#events ContentTabs Tab:hover,
#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab,
#events ContentTabs:focus Tab.-active {
    background: $background;
    background-tint: transparent;
}

#events ContentTabs Tab {
    color: $text-muted;
}

#events ContentTabs Tab:hover,
#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab.-active {
    color: $text;
}

#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab.-active {
    text-style: bold;
}

#events ContentTabs:focus .underline--bar {
    background: $surface-lighten-2;
}

#conversation {
    height: 1fr;
    border: none;
    background: $surface;
    color: $text;
    overflow-x: hidden;
}

#logs, #terminal {
    height: 1fr;
    border: none;
    background: $background;
    color: $text;
    overflow-x: hidden;
}

ConversationEntryWidget {
    height: auto;
    padding-bottom: 1;
}

ConversationEntryWidget.entry-thinking,
ConversationEntryWidget.entry-progress,
ConversationEntryWidget.entry-skill,
ConversationEntryWidget.entry-sub_agent,
ConversationEntryWidget.entry-workflow {
    padding-left: 2;
}

ToolEntryWidget {
    height: auto;
    padding-bottom: 1;
}

ToolEntryWidget Collapsible {
    background: transparent;
    border-top: none;
    padding-bottom: 0;
    padding-left: 0;
}

ToolEntryWidget CollapsibleTitle {
    padding: 0 1 0 0;
}

ToolEntryWidget Collapsible Contents {
    padding-left: 2;
}

ToolEntryWidget .tool-preview {
    height: auto;
    padding-left: 2;
}

ToolEntryWidget.agent-activity CollapsibleTitle {
    padding: 0 1 0 2;
}

ToolEntryWidget.agent-activity Collapsible Contents {
    padding-left: 4;
}

ToolEntryWidget.agent-activity .tool-preview {
    padding-left: 4;
}

ToolEntryWidget .tool-body {
    color: $text-muted;
}

#jump_to_bottom {
    display: none;
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
    text-align: center;
}

#status_form, #planning_form {
    height: 1fr;
    background: $background;
    color: $text;
    padding: 1;
}

#settings_summary_panel {
    height: 1fr;
    padding: 1;
    background: $background;
}

#settings_summary {
    height: auto;
    padding: 1 0;
}

#settings_summary_status {
    height: auto;
    margin-top: 1;
}

#open_settings {
    width: auto;
    min-width: 12;
    margin-top: 1;
}

#status_dashboard {
    height: auto;
    min-height: 15;
    border: none;
    background: $background;
    color: $text;
    padding: 1 0 1 1;
}

#status_task_list_markdown {
    padding: 0 0 1 0;
}

.status-section,
.planning-section,
.settings-section {
    height: auto;
    border: round $surface-lighten-2;
    border-title-color: $text;
    border-title-style: bold;
    background: $background;
    padding: 0 1;
    margin-bottom: 1;
}

#mcp_status {
    height: auto;
    margin-bottom: 1;
}

.settings-button-row {
    height: auto;
    min-height: 3;
    margin-top: 1;
    align-horizontal: left;
}

.settings-button-row Button {
    width: auto;
    min-width: 12;
    margin: 0 1 0 0;
}

.settings-hint {
    color: $text-muted;
    margin-top: 0;
}

.agent-model-group {
    height: auto;
    margin-top: 1;
}

.agent-model-role {
    text-style: bold;
    color: $text;
}

.agent-model-field {
    height: auto;
    margin-top: 1;
}

.agent-model-field-label {
    width: 10;
    margin-top: 1;
    color: $text-muted;
}

.agent-model-field Select {
    width: 1fr;
}

SettingsScreen {
    align: center middle;
    background: $background;
    color: $text;
}

SettingsScreen #settings_screen_header {
    height: 3;
    padding: 1 2 0 2;
    text-style: bold;
    background: $surface;
}

SettingsScreen #settings_screen_body {
    height: 1fr;
    width: 100%;
}

SettingsScreen #settings_categories {
    width: 24;
    height: 100%;
    border: none;
    border-right: solid $surface-lighten-2;
    background: $background;
    padding: 1;
}

SettingsScreen #settings_screen_detail {
    width: 1fr;
    height: 100%;
    background: $background;
}

SettingsScreen .settings-page {
    width: 100%;
    height: 1fr;
    padding: 1 2;
    background: $background;
}

SettingsScreen Select > SelectCurrent,
SettingsScreen Select > SelectOverlay {
    background: $panel;
    border: round $surface-lighten-2;
    color: $text;
}

SettingsScreen Select:focus > SelectCurrent {
    background: $panel;
    border: round $surface-lighten-2;
    background-tint: transparent;
}

SettingsScreen Select.settings-select-small {
    width: 1fr;
    max-width: 22;
}

SettingsScreen Select.settings-select-medium {
    width: 1fr;
    max-width: 34;
}

SettingsScreen Select.settings-select-wide {
    width: 1fr;
    max-width: 50;
}

Button.settings-action {
    width: auto;
    min-width: 12;
    background: transparent;
    border: tall $surface-lighten-2;
    color: $text;
    text-style: none;
    background-tint: transparent;
}

Button.settings-action:hover,
Button.settings-action:focus,
Button.settings-action.-active {
    background: $surface-lighten-2;
    border: tall $surface-lighten-2;
    background-tint: transparent;
    tint: transparent;
}

Button.settings-action.-primary {
    background: transparent;
    border: tall $primary;
    color: $primary;
}

Button.settings-action.-primary:hover,
Button.settings-action.-primary:focus,
Button.settings-action.-primary.-active {
    background: $surface-lighten-2;
    border: tall $primary;
    color: $primary;
}

Button.settings-action.-warning {
    background: transparent;
    border: tall $warning;
    color: $warning;
}

Button.settings-action.-warning:hover,
Button.settings-action.-warning:focus,
Button.settings-action.-warning.-active {
    background: $surface-lighten-2;
    border: tall $warning;
    color: $warning;
}

Button.settings-action.-error {
    background: transparent;
    border: tall $error;
    color: $error;
}

Button.settings-action.-error:hover,
Button.settings-action.-error:focus,
Button.settings-action.-error.-active {
    background: $surface-lighten-2;
    border: tall $error;
    color: $error;
}

Button.settings-action:disabled {
    background: transparent;
    border: tall $surface;
    color: $text-muted;
    text-opacity: 0.6;
}

SettingsScreen Label,
SettingsScreen Button {
    margin-top: 1;
}

SettingsScreen #settings_screen_footer {
    height: auto;
    min-height: 5;
    padding: 0 2 1 2;
    border-top: solid $surface-lighten-2;
    background: $surface;
}

SettingsScreen #settings_screen_actions {
    height: auto;
    align-horizontal: right;
}

SettingsScreen #settings_screen_actions Button {
    width: auto;
    min-width: 12;
    margin-left: 1;
}

SettingsScreen #settings_status,
SettingsScreen #settings_connection_status {
    height: auto;
    margin-top: 1;
}

ConfirmDiscardSettingsScreen,
ConfirmSettingsActionScreen {
    align: center middle;
    background: $background 80%;
}

#settings_discard_dialog {
    width: 64;
    height: auto;
    padding: 1 2;
    border: round $surface-lighten-2;
    background: $surface;
}

#settings_discard_title {
    height: auto;
    text-style: bold;
}

#settings_discard_copy {
    height: auto;
    margin-top: 1;
}

#settings_discard_actions {
    height: auto;
    align-horizontal: right;
}

#settings_discard_actions Button {
    width: auto;
    min-width: 12;
    margin-left: 1;
}

#settings_action_dialog {
    width: 68;
    max-width: 94%;
    height: auto;
    padding: 1 2;
    border: round $surface-lighten-2;
    background: $surface;
}

#settings_action_title {
    height: auto;
    text-style: bold;
}

#settings_action_copy {
    height: auto;
    margin-top: 1;
}

#settings_action_buttons {
    height: auto;
    align-horizontal: right;
}

#settings_action_buttons Button {
    width: auto;
    min-width: 12;
    margin-left: 1;
}

OnboardingScreen {
    align: center middle;
    background: $background;
    color: $text;
}

#onboarding_dialog {
    width: 76;
    max-width: 96%;
    height: auto;
    max-height: 94%;
    padding: 1 2;
    border: round $surface-lighten-2;
    background: $surface;
}

#onboarding_title {
    height: auto;
    text-style: bold;
}

#onboarding_progress,
.onboarding-hint {
    height: auto;
    color: $text-muted;
}

#onboarding_pages,
.onboarding-step,
#onboarding_chatgpt_panel,
#onboarding_api_panel {
    height: auto;
}

.onboarding-step {
    margin-top: 1;
}

OnboardingScreen Label,
OnboardingScreen Button {
    margin-top: 1;
}

OnboardingScreen Select > SelectCurrent,
OnboardingScreen Select > SelectOverlay {
    background: $panel;
    border: round $surface-lighten-2;
    color: $text;
}

#onboarding_status,
#onboarding_chatgpt_status,
#onboarding_test_status,
#onboarding_summary {
    height: auto;
    margin-top: 1;
}

#onboarding_actions {
    height: auto;
    margin-top: 1;
    align-horizontal: right;
}

#onboarding_actions Button {
    width: 18;
    margin-left: 1;
}

#status_form PlanningMarkdown,
#planning_form PlanningMarkdown {
    height: auto;
}

#status_form PlanningMarkdown.empty-state,
#planning_form PlanningMarkdown.empty-state {
    color: $text-muted;
}

#queued_messages {
    display: none;
    height: auto;
    max-height: 8;
    padding: 0 1;
    border-top: solid $surface-lighten-2;
    background: $surface;
    color: $warning;
}

#composer {
    dock: bottom;
    height: auto;
    min-height: 5;
    max-height: 15;
    padding: 0 0 0 1;
    border: none;
    border-top: solid $surface-lighten-2;
    background: $surface;
    color: $text;
}

#composer:focus,
#composer:disabled,
#composer:disabled:focus {
    opacity: 1;
    color: $text;
    background: $surface;
    background-tint: transparent;
    border: none;
    border-top: solid $surface-lighten-2;
}

#composer:disabled .text-area--cursor {
    background: $surface-lighten-2;
    color: $text-muted;
}

#composer .text-area--selection,
#composer:disabled .text-area--selection {
    background: $surface-lighten-2;
    color: $text;
}

#composer .text-area--cursor-line,
#composer:disabled .text-area--cursor-line {
    background: transparent;
}

#composer .text-area--gutter,
#composer:disabled .text-area--gutter {
    color: $text;
    background: $surface;
}

#composer .text-area--cursor-gutter,
#composer:disabled .text-area--cursor-gutter {
    color: $text;
    background: $surface;
}

#composer .text-area--placeholder,
#composer:disabled .text-area--placeholder {
    color: $text 40%;
}

#turn_status {
    display: none;
    height: 1;
    padding: 0 1;
    color: $text-muted;
    background: $surface;
}

#composer_hint_row {
    display: none;
    height: auto;
    max-height: 4;
    background: $surface;
}

#composer_hint_row #composer_hint {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

#composer_hint_row #detach_btn {
    width: 3;
    height: 1;
    min-height: 1;
    border: none;
    background: transparent;
    color: $text-muted;
    padding: 0 1;
}

#composer_hint_row #detach_btn:hover {
    color: $warning;
}

#composer_hint_row #detach_btn:focus {
    color: $warning;
    text-style: bold;
}

#completion_dropdown {
    display: none;
    height: auto;
    max-height: 10;
    border: round $surface;
    background: $surface;
}

#composer_hint.hint-warning {
    color: $warning;
}

#composer_hint.hint-info {
    color: $text-muted;
}

#plan_actions,
#plan_actions:focus {
    display: none;
    height: auto;
    max-height: 12;
    border: none;
    background: $surface;
    background-tint: transparent;
    padding: 0;
    margin: 0;
}

#plan_actions > .option-list--option {
    padding: 0 1;
}

#model_actions, #effort_actions, #theme_actions {
    display: none;
    height: auto;
    max-height: 12;
    border: round $surface;
    background: $surface;
}

/* Question / approval prompts align flush with the transcript/composer edges.
   The prompt text and choices should not add their own box/border chrome; the
   active row highlight is enough to show selection. */
#question_prompt, #approval_prompt {
    display: none;
    height: auto;
    max-height: 14;
    border: none;
    background: $surface;
    padding: 0;
    margin: 0;
}

#question_prompt > .prompt-header-scroll, #approval_prompt > .prompt-header-scroll {
    height: auto;
    max-height: 6;
    overflow-y: auto;
    background: $surface;
    margin-bottom: 1;
}

#question_prompt > ActionList, #approval_prompt > ActionList,
#question_prompt > ActionList:focus, #approval_prompt > ActionList:focus {
    border: none;
    background: $surface;
    background-tint: transparent;
    height: auto;
    max-height: 6;
    padding: 0;
}

.prompt-header {
    height: auto;
    padding: 0 1 1 1;
    background: $surface;
}

#question_prompt > ActionList > .option-list--option,
#approval_prompt > ActionList > .option-list--option {
    padding: 0 1;
}

/* Neutralize the selected-row highlight on every choice list. Textual paints
   it with $block-cursor-background (= $primary, a saturated brand color),
   which clashes with the otherwise-neutral chrome and looks wrong in 256-color
   Terminal.app. Each theme pins $surface-lighten-2 to a near-neutral gray
   (see theme.build_textual_theme) so the highlight stays subtle across all
   themes — incl. Solarized, whose auto-derived $surface-lighten-2 would
   otherwise quantize to a saturated teal. The OptionList type selector also
   covers its subclasses: ActionList, CompletionDropdown, and the Select's
   SelectOverlay dropdown. */
OptionList > .option-list--option-highlighted {
    background: $surface-lighten-2;
    color: $text;
}

.meta {
    color: $text-muted;
}

#session_meta {
    background: $background;
    color: $text-muted;
}

Footer {
    background: $background;
    color: $text-muted;
}

Footer > .footer--highlight {
    background: $surface-lighten-2;
    color: $text;
}

Input {
    border: round $surface;
}

Input:focus {
    border: round $surface-lighten-2;
}

Select > SelectCurrent {
    border: round $surface;
}

Select:focus > SelectCurrent {
    border: round $surface-lighten-2;
}

Select > SelectOverlay {
    border: round $surface;
    background: $surface;
    color: $text;
}

SubAgentInspectorScreen {
    align: center middle;
}

SubAgentInspectorScreen #inspector_body {
    width: 100%;
    height: 1fr;
}

SubAgentInspectorScreen #inspector_roster {
    width: 40;
    height: 100%;
    border: round $surface;
    padding: 0 1;
}

SubAgentInspectorScreen #inspector_main {
    width: 1fr;
    height: 100%;
}

SubAgentInspectorScreen #inspector_header {
    height: auto;
    border: round $surface;
    padding: 0 1;
}

SubAgentInspectorScreen #inspector_trajectory {
    height: 1fr;
    border: round $surface;
    padding: 0 1;
}

SubAgentRosterRow {
    height: auto;
    padding: 0 0 1 0;
}

SubAgentInspectorScreen .inspector-empty {
    color: $text-muted;
    padding: 1;
}

SubAgentInspectorScreen #inspector_footer {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
}

ChangesInspectorScreen {
    align: center middle;
}

ChangesInspectorScreen #changes_body {
    width: 100%;
    height: 1fr;
}

ChangesInspectorScreen #changes_roster {
    width: 44;
    height: 100%;
    border: round $surface;
    padding: 0 1;
}

ChangesInspectorScreen #changes_main {
    width: 1fr;
    height: 100%;
}

ChangesInspectorScreen #changes_header {
    height: auto;
    border: round $surface;
    padding: 0 1;
}

ChangesInspectorScreen #changes_previews {
    height: 1fr;
    border: round $surface;
    padding: 0 1;
}

ChangeFileRosterRow {
    height: auto;
    padding: 0 0 1 0;
}

ChangesInspectorScreen .changes-empty {
    color: $text-muted;
    padding: 1;
}

ChangesInspectorScreen .change-preview {
    height: auto;
    padding-bottom: 1;
}

ChangesInspectorScreen #changes_footer {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
}
