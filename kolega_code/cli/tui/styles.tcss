Screen {
    layout: vertical;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface-lighten-2;
    scrollbar-color: $surface-lighten-2;
    scrollbar-color-hover: $text-muted;
    scrollbar-color-active: $text;
    scrollbar-corner-color: $surface;
}

#body {
    height: 1fr;
}

#conversation_panel {
    width: 2fr;
    height: 100%;
}

#side_panel {
    width: 1fr;
    min-width: 34;
    height: 100%;
    background: $background;
}

#events {
    background: $background;
    color: $text;
}

#events > ContentTabs,
#events ContentTabs > #tabs-scroll,
#events ContentTabs #tabs-list-bar,
#events ContentTabs #tabs-list {
    background: $background;
    color: $text;
}

#events ContentTabs Tab,
#events ContentTabs Tab:hover,
#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab,
#events ContentTabs:focus Tab.-active {
    background: $background;
    background-tint: transparent;
}

#events ContentTabs Tab {
    color: $text-muted;
}

#events ContentTabs Tab:hover,
#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab.-active {
    color: $text;
}

#events ContentTabs Tab.-active,
#events ContentTabs:focus Tab.-active {
    text-style: bold;
}

#events ContentTabs:focus .underline--bar {
    background: $surface-lighten-2;
}

#conversation {
    height: 1fr;
    border: none;
    background: $surface;
    color: $text;
    overflow-x: hidden;
}

#logs, #terminal {
    height: 1fr;
    border: none;
    background: $background;
    color: $text;
    overflow-x: hidden;
}

ConversationEntryWidget {
    height: auto;
    padding-bottom: 1;
}

/* Activity entries nest one 2-cell step under the message flow. All four
   padding edges must be set together: Textual keeps only the most-specific
   rule per style key, and `padding` is ONE key — a bare padding-left here
   would silently zero the base rule's padding-bottom. */
ConversationEntryWidget.entry-progress,
ConversationEntryWidget.entry-skill,
ConversationEntryWidget.entry-sub_agent,
ConversationEntryWidget.entry-workflow {
    padding: 0 0 1 2;
}

ToolEntryWidget {
    height: auto;
    padding-bottom: 1;
}

ToolEntryWidget Collapsible {
    background: transparent;
    border-top: none;
    padding-bottom: 0;
    padding-left: 0;
}

ToolEntryWidget CollapsibleTitle {
    padding: 0 1 0 0;
}

ToolEntryWidget Collapsible Contents {
    padding-left: 2;
}

ToolEntryWidget .tool-preview {
    height: auto;
    padding-left: 2;
}

ToolEntryWidget.agent-activity CollapsibleTitle {
    padding: 0 1 0 2;
}

ToolEntryWidget.agent-activity Collapsible Contents {
    padding-left: 4;
}

ToolEntryWidget.agent-activity .tool-preview {
    padding-left: 4;
}

ToolEntryWidget .tool-body {
    color: $text-muted;
}

#jump_to_bottom {
    display: none;
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
    text-align: center;
}

#status_form, #planning_form {
    height: 1fr;
    background: $background;
    color: $text;
    padding: 1;
}

#settings_summary_panel {
    height: 1fr;
    padding: 1;
    background: $background;
}

#settings_summary {
    height: auto;
    padding: 1 0;
}

#settings_summary_status {
    height: auto;
    margin-top: 1;
}

#open_settings {
    width: auto;
    min-width: 12;
    margin-top: 1;
}

#status_dashboard {
    height: auto;
    min-height: 15;
    border: none;
    background: $background;
    color: $text;
    padding: 1 0 1 1;
}

#status_task_list_markdown {
    padding: 0 0 1 0;
}

.status-section,
.planning-section,
.settings-section {
    height: auto;
    border: round $surface-lighten-2;
    border-title-color: $text;
    border-title-style: bold;
    background: $background;
    padding: 0 1;
    margin-bottom: 1;
}

#mcp_status {
    height: auto;
    margin-bottom: 1;
}

.settings-button-row {
    height: auto;
    min-height: 3;
    margin-top: 1;
    align-horizontal: left;
}

.settings-button-row Button {
    width: auto;
    min-width: 12;
    margin-right: 1;
}

.settings-hint {
    color: $text-muted;
    margin-top: 0;
}

.agent-model-group {
    height: auto;
    margin-top: 1;
}

.agent-model-role {
    text-style: bold;
    color: $text;
}

.agent-model-field {
    height: auto;
    margin-top: 1;
}

.agent-model-field-label {
    width: 10;
    margin-top: 1;
    color: $text-muted;
}

SettingsScreen {
    align: center middle;
    background: $background;
    color: $text;
}

SettingsScreen #settings_screen_header {
    height: 3;
    padding: 1 2 0 2;
    background: $surface;
    border-bottom: solid $surface-lighten-2;
}

SettingsScreen #settings_screen_title {
    width: auto;
    height: auto;
    text-style: bold;
}

SettingsScreen #settings_screen_hint {
    width: 1fr;
    height: auto;
    text-align: right;
    color: $text-muted;
}

SettingsScreen #settings_screen_body {
    height: 1fr;
    width: 100%;
}

SettingsScreen #settings_categories {
    width: 24;
    height: 100%;
    border: none;
    border-right: solid $surface-lighten-2;
    background: $background;
    padding: 1;
}

SettingsScreen #settings_screen_detail {
    width: 1fr;
    height: 100%;
    background: $background;
}

SettingsScreen .settings-page {
    width: 100%;
    height: 1fr;
    padding: 1 2;
    background: $background;
}

/* Slim, neutral scrollbars inside the editors (scrollbar-* does not
   inherit, so the Screen-level palette must be restated here). */
SettingsScreen .settings-page,
SettingsScreen #settings_categories,
#onboarding_pages {
    scrollbar-size-vertical: 1;
    scrollbar-color: $surface-lighten-2;
    scrollbar-color-hover: $text-muted;
    scrollbar-color-active: $text;
}

SettingsScreen .settings-page,
SettingsScreen #settings_categories {
    scrollbar-background: $background;
}

#onboarding_pages {
    scrollbar-background: $surface;
}

/* Flat control chrome. Border glyphs never fill their cells cleanly against
   the $panel fill (rounded lines leave a squared halo, tall bars leave
   notches), so controls are borderless flat boxes: explicit height keeps the
   3-row shape and focus is shown by brightening the fill. */
SettingsScreen Select > SelectCurrent,
SettingsScreen .settings-page Input {
    background: $panel;
    border: none;
    height: 3;
    padding: 1 2;
    color: $text;
}

SettingsScreen Select > SelectOverlay {
    background: $panel;
    border: solid $surface-lighten-2;
    color: $text;
}

SettingsScreen Select:focus > SelectCurrent,
SettingsScreen .settings-page Input:focus {
    background: $surface-lighten-2;
    border: none;
    background-tint: transparent;
}

/* One uniform width for every form control. 46 = longest option label
   (38 cells, "Server-Sent Events (legacy/deprecated)") + Select chrome
   (2 border + 4 padding + 2 arrow). The overlay is 1fr of its Select, so
   it inherits the same width. */
SettingsScreen .settings-page Select,
SettingsScreen .settings-page Input,
#onboarding_dialog Select,
#onboarding_dialog Input {
    width: 1fr;
    max-width: 46;
}

/* Agent-model rows: 10-col label + 36-col control aligns the right edge
   with the 46-col controls above. Must come after the shared rule (equal
   specificity, later wins). */
SettingsScreen .agent-model-field Select {
    width: 1fr;
    max-width: 36;
}

/* Quiet buttons: text-only secondary actions. Borderless with an explicit
   height — every border glyph style (tall/round/block) leaves visible seams
   against a fill — so the pill stays 3 rows tall with perfectly clean edges;
   hover/focus fill it. */
Button.quiet {
    width: auto;
    min-width: 12;
    height: 3;
    padding: 0 2;
    background: transparent;
    border: none;
    color: $text;
    text-style: none;
    background-tint: transparent;
}

Button.quiet:hover,
Button.quiet:focus,
Button.quiet.-active {
    background: $surface-lighten-2;
    border: none;
    background-tint: transparent;
    tint: transparent;
}

Button.quiet.danger {
    color: $error;
}

Button.quiet:disabled {
    background: transparent;
    border: none;
    color: $text-muted;
    text-opacity: 0.6;
}

/* The one solid call-to-action per surface. Owned here rather than via
   variant="primary" so no default bevel borders leak edge artifacts. */
Button.solid-primary {
    width: auto;
    min-width: 12;
    height: 3;
    padding: 0 2;
    background: $primary;
    border: none;
    color: $text;
    text-style: bold;
    background-tint: transparent;
}

Button.solid-primary:hover,
Button.solid-primary:focus,
Button.solid-primary.-active {
    background: $primary-darken-1;
    border: none;
    background-tint: transparent;
    tint: transparent;
}

Button.solid-primary:disabled {
    background: $panel;
    border: none;
    color: $text-muted;
    text-style: none;
    text-opacity: 0.6;
}

SettingsScreen .settings-section > Label,
SettingsScreen .settings-section > Button {
    margin-top: 1;
}

/* Single-row footer: the status text sits left on the same band as the
   action buttons, so the footer is only as tall as the buttons. */
SettingsScreen #settings_screen_footer {
    height: auto;
    padding: 0 2;
    border-top: solid $surface-lighten-2;
    background: $surface;
}

SettingsScreen #settings_status {
    width: 1fr;
    height: auto;
    min-height: 3;
    content-align: left middle;
    margin-right: 2;
}

SettingsScreen #settings_screen_actions {
    width: auto;
    height: auto;
}

SettingsScreen #settings_screen_actions Button {
    width: auto;
    min-width: 12;
    margin-left: 1;
}

SettingsScreen #settings_connection_status {
    height: auto;
    margin-top: 1;
}

ConfirmDiscardSettingsScreen,
ConfirmSettingsActionScreen {
    align: center middle;
    background: $background 80%;
}

/* One shared card style for every centered dialog. */
.modal-dialog {
    width: 72;
    max-width: 90%;
    height: auto;
    max-height: 90%;
    padding: 1 2;
    border: round $surface-lighten-2;
    background: $surface;
}

#settings_discard_title,
#settings_action_title {
    height: auto;
    text-style: bold;
}

#settings_discard_copy,
#settings_action_copy {
    height: auto;
    margin-top: 1;
}

#settings_discard_actions,
#settings_action_buttons,
#onboarding_actions {
    height: auto;
    margin-top: 1;
    align-horizontal: right;
}

#settings_discard_actions Button,
#settings_action_buttons Button,
#onboarding_actions Button {
    width: auto;
    min-width: 12;
    margin-left: 1;
}

/* Muted keybinding hint sitting left of a right-aligned action row; its
   1fr width pushes the buttons to the right edge. */
.dialog-hint {
    width: 1fr;
    height: auto;
    margin-top: 1;
    color: $text-muted;
}

OnboardingScreen {
    align: center middle;
    background: $background;
    color: $text;
}

#onboarding_title {
    height: auto;
    text-style: bold;
}

#onboarding_progress,
.onboarding-hint {
    height: auto;
    color: $text-muted;
}

/* Fixed-height wizard card: the frame (title, progress, status, actions)
   never moves between steps, and the step content scrolls in the middle
   when the terminal is short — the action row can never fall off-screen.
   27 = tallest step (16 rows, connection with the API panel) + frame (11). */
#onboarding_dialog {
    height: 27;
}

#onboarding_pages {
    height: 1fr;
}

.onboarding-step,
#onboarding_chatgpt_panel,
#onboarding_api_panel {
    height: auto;
}

.onboarding-step {
    margin-top: 1;
}

#onboarding_pages Label,
#onboarding_pages Button {
    margin-top: 1;
}

OnboardingScreen Select > SelectCurrent,
#onboarding_dialog Input {
    background: $panel;
    border: none;
    height: 3;
    padding: 1 2;
    color: $text;
}

OnboardingScreen Select > SelectOverlay {
    background: $panel;
    border: solid $surface-lighten-2;
    color: $text;
}

OnboardingScreen Select:focus > SelectCurrent,
#onboarding_dialog Input:focus {
    background: $surface-lighten-2;
    border: none;
    background-tint: transparent;
}

#onboarding_status,
#onboarding_chatgpt_status,
#onboarding_test_status,
#onboarding_summary {
    height: auto;
    margin-top: 1;
}

#status_form PlanningMarkdown,
#planning_form PlanningMarkdown {
    height: auto;
}

#status_form PlanningMarkdown.empty-state,
#planning_form PlanningMarkdown.empty-state {
    color: $text-muted;
}

#queued_messages {
    display: none;
    height: auto;
    max-height: 8;
    padding: 0 1;
    border-top: solid $surface-lighten-2;
    background: $surface;
    color: $warning;
}

#composer {
    dock: bottom;
    height: auto;
    min-height: 5;
    max-height: 15;
    padding: 0 0 0 1;
    border: none;
    border-top: solid $surface-lighten-2;
    background: $surface;
    color: $text;
}

#composer:focus,
#composer:disabled,
#composer:disabled:focus {
    opacity: 1;
    color: $text;
    background: $surface;
    background-tint: transparent;
    border: none;
    border-top: solid $surface-lighten-2;
}

#composer:disabled .text-area--cursor {
    background: $surface-lighten-2;
    color: $text-muted;
}

#composer .text-area--selection,
#composer:disabled .text-area--selection {
    background: $surface-lighten-2;
    color: $text;
}

#composer .text-area--cursor-line,
#composer:disabled .text-area--cursor-line {
    background: transparent;
}

#composer .text-area--gutter,
#composer:disabled .text-area--gutter {
    color: $text;
    background: $surface;
}

#composer .text-area--cursor-gutter,
#composer:disabled .text-area--cursor-gutter {
    color: $text;
    background: $surface;
}

#composer .text-area--placeholder,
#composer:disabled .text-area--placeholder {
    color: $text 40%;
}

#turn_status {
    display: none;
    height: 1;
    padding: 0 1;
    color: $text-muted;
    background: $surface;
}

#composer_hint_row {
    display: none;
    height: auto;
    max-height: 4;
    background: $surface;
}

#composer_hint_row #composer_hint {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

#composer_hint_row #detach_btn {
    width: 3;
    height: 1;
    min-height: 1;
    border: none;
    background: transparent;
    color: $text-muted;
    padding: 0 1;
}

#composer_hint_row #detach_btn:hover {
    color: $warning;
}

#composer_hint_row #detach_btn:focus {
    color: $warning;
    text-style: bold;
}

#completion_dropdown {
    display: none;
    height: auto;
    max-height: 10;
    border: round $surface;
    background: $surface;
}

#composer_hint.hint-warning {
    color: $warning;
}

#composer_hint.hint-info {
    color: $text-muted;
}

#plan_actions,
#plan_actions:focus {
    display: none;
    height: auto;
    max-height: 12;
    border: none;
    background: $surface;
    background-tint: transparent;
    padding: 0;
    margin: 0;
}

#plan_actions > .option-list--option {
    padding: 0 1;
}

#model_actions, #effort_actions, #theme_actions {
    display: none;
    height: auto;
    max-height: 12;
    border: round $surface;
    background: $surface;
}

/* Question / approval prompts align flush with the transcript/composer edges.
   The prompt text and choices should not add their own box/border chrome; the
   active row highlight is enough to show selection. */
#question_prompt, #approval_prompt {
    display: none;
    height: auto;
    max-height: 14;
    border: none;
    background: $surface;
    padding: 0;
    margin: 0;
}

#question_prompt > .prompt-header-scroll, #approval_prompt > .prompt-header-scroll {
    height: auto;
    max-height: 6;
    overflow-y: auto;
    background: $surface;
    margin-bottom: 1;
}

#question_prompt > ActionList, #approval_prompt > ActionList,
#question_prompt > ActionList:focus, #approval_prompt > ActionList:focus {
    border: none;
    background: $surface;
    background-tint: transparent;
    height: auto;
    max-height: 6;
    padding: 0;
}

.prompt-header {
    height: auto;
    padding: 0 1 1 1;
    background: $surface;
}

#question_prompt > ActionList > .option-list--option,
#approval_prompt > ActionList > .option-list--option {
    padding: 0 1;
}

/* Neutralize the selected-row highlight on every choice list. Textual paints
   it with $block-cursor-background (= $primary, a saturated brand color),
   which clashes with the otherwise-neutral chrome and looks wrong in 256-color
   Terminal.app. Each theme pins $surface-lighten-2 to a near-neutral gray
   (see theme.build_textual_theme) so the highlight stays subtle across all
   themes — incl. Solarized, whose auto-derived $surface-lighten-2 would
   otherwise quantize to a saturated teal. The OptionList type selector also
   covers its subclasses: ActionList, CompletionDropdown, and the Select's
   SelectOverlay dropdown. */
OptionList > .option-list--option-highlighted {
    background: $surface-lighten-2;
    color: $text;
}

.meta {
    color: $text-muted;
}

#session_meta {
    background: $background;
    color: $text-muted;
}

Footer {
    background: $background;
    color: $text-muted;
}

Footer > .footer--highlight {
    background: $surface-lighten-2;
    color: $text;
}

Input {
    border: round $surface;
}

Input:focus {
    border: round $surface-lighten-2;
}

Select > SelectCurrent {
    border: round $surface;
}

Select:focus > SelectCurrent {
    border: round $surface-lighten-2;
}

Select > SelectOverlay {
    border: round $surface;
    background: $surface;
    color: $text;
}

SubAgentInspectorScreen {
    align: center middle;
}

SubAgentInspectorScreen #inspector_body {
    width: 100%;
    height: 1fr;
}

SubAgentInspectorScreen #inspector_roster {
    width: 40;
    height: 100%;
    border: round $surface;
    padding: 0 1;
}

SubAgentInspectorScreen #inspector_main {
    width: 1fr;
    height: 100%;
}

SubAgentInspectorScreen #inspector_header {
    height: auto;
    border: round $surface;
    padding: 0 1;
}

SubAgentInspectorScreen #inspector_trajectory {
    height: 1fr;
    border: round $surface;
    padding: 0 1;
}

SubAgentRosterRow {
    height: auto;
    padding: 0 0 1 0;
}

SubAgentInspectorScreen .inspector-empty {
    color: $text-muted;
    padding: 1;
}

SubAgentInspectorScreen #inspector_footer {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
}

ChangesInspectorScreen {
    align: center middle;
}

ChangesInspectorScreen #changes_body {
    width: 100%;
    height: 1fr;
}

ChangesInspectorScreen #changes_roster {
    width: 44;
    height: 100%;
    border: round $surface;
    padding: 0 1;
}

ChangesInspectorScreen #changes_main {
    width: 1fr;
    height: 100%;
}

ChangesInspectorScreen #changes_header {
    height: auto;
    border: round $surface;
    padding: 0 1;
}

ChangesInspectorScreen #changes_previews {
    height: 1fr;
    border: round $surface;
    padding: 0 1;
}

ChangeFileRosterRow {
    height: auto;
    padding: 0 0 1 0;
}

ChangesInspectorScreen .changes-empty {
    color: $text-muted;
    padding: 1;
}

ChangesInspectorScreen .change-preview {
    height: auto;
    padding-bottom: 1;
}

ChangesInspectorScreen #changes_footer {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
}
